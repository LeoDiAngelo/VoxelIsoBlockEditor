<Window x:Class="IsoBlockCharacterEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:IsoBlockCharacterEditor"
        Title="Voxel Iso Block Editor" Width="1500" Height="920" WindowState="Maximized"
        WindowStartupLocation="CenterScreen" Background="#0E1218"
        Loaded="Window_Loaded" PreviewKeyDown="Window_PreviewKeyDown" PreviewKeyUp="Window_PreviewKeyUp" UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Window.Resources>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Margin" Value="0,4,0,8"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Background" Value="#F3F7FF"/>
            <Setter Property="Foreground" Value="#0F1722"/>
            <Setter Property="BorderBrush" Value="#607086"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#F3F7FF"/>
            <Setter Property="Foreground" Value="#0F1722"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="#263348"/>
            <Setter Property="Foreground" Value="#F3F7FF"/>
            <Setter Property="BorderBrush" Value="#40516A"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="7,3"/>
            <Setter Property="Background" Value="#101722"/>
            <Setter Property="Foreground" Value="#F3F7FF"/>
            <Setter Property="BorderBrush" Value="#40516A"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F3F7FF"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#F3F7FF"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="330"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="330"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#171D27" BorderBrush="#2B3444" BorderThickness="0,0,1,0" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="VOXEL ISO BLOCK EDITOR" Foreground="#F3F7FF" FontSize="21" FontWeight="Bold"/>
                    <TextBlock Text="MonoGame hardware accelerated viewport with clean voxel wire grids." Foreground="#AAB5C7" TextWrapping="Wrap" Margin="0,5,0,16"/>

                    <TextBlock Text="Block piece" Foreground="#F3F7FF" FontWeight="SemiBold"/>
                    <DockPanel>
                        <Button Content="Library…" Width="86" DockPanel.Dock="Right" Margin="6,0,0,0" Click="OpenLibrary_Click"/>
                        <ComboBox x:Name="ShapeCombo" SelectedValuePath="Shape" SelectionChanged="ShapeCombo_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </DockPanel>

                    <TextBlock Text="Editor mode" Foreground="#F3F7FF" FontWeight="SemiBold" Margin="0,10,0,4"/>
                    <UniformGrid Columns="2" Margin="0,0,0,8">
                        <RadioButton x:Name="BuildModeCheck" GroupName="EditorMode" IsChecked="True" Content="Build" Checked="Mode_Checked"/>
                        <RadioButton x:Name="SelectModeCheck" GroupName="EditorMode" Content="Select" Checked="Mode_Checked"/>
                    </UniformGrid>
                    <CheckBox x:Name="ShowEdgesCheck" IsChecked="False" Content="Show green bevel edges" Click="GridOption_Click"/>
                    <CheckBox x:Name="ShowFloorGridCheck" IsChecked="True" Content="Show floor grid X/Z" Click="GridOption_Click"/>
                    <CheckBox x:Name="ShowBackGridCheck" IsChecked="True" Content="Show left side grid Y/Z" Click="GridOption_Click"/>
                    <CheckBox x:Name="ShowSideGridCheck" IsChecked="True" Content="Show right side grid X/Y" Click="GridOption_Click"/>
                    <CheckBox x:Name="ShowInfoCheck" IsChecked="True" Content="Show viewport info" Click="GridOption_Click"/>

                    <Separator Margin="0,14" Background="#2B3444"/>
                    <TextBlock Text="Color" Foreground="#F3F7FF" FontWeight="SemiBold"/>
                    <UniformGrid Columns="4" Margin="0,7,0,5">
                        <Button Height="32" Background="#D84C4C" Tag="#D84C4C" Click="PresetColor_Click"/>
                        <Button Height="32" Background="#E2A83C" Tag="#E2A83C" Click="PresetColor_Click"/>
                        <Button Height="32" Background="#60B35F" Tag="#60B35F" Click="PresetColor_Click"/>
                        <Button Height="32" Background="#4B88D8" Tag="#4B88D8" Click="PresetColor_Click"/>
                        <Button Height="32" Background="#8D65DA" Tag="#8D65DA" Click="PresetColor_Click"/>
                        <Button Height="32" Background="#D77CC4" Tag="#D77CC4" Click="PresetColor_Click"/>
                        <Button Height="32" Background="#CBD1DC" Tag="#CBD1DC" Click="PresetColor_Click"/>
                        <Button Height="32" Background="#2D3542" Tag="#2D3542" Click="PresetColor_Click"/>
                    </UniformGrid>
                    <DockPanel>
                        <Border x:Name="ColorPreview" Width="34" Height="34" Background="#4B88D8" BorderBrush="#607086" BorderThickness="1" CornerRadius="4" DockPanel.Dock="Right" Margin="5,3,0,3"/>
                        <TextBox x:Name="ColorText" Text="#4B88D8" LostFocus="ColorText_LostFocus"/>
                    </DockPanel>

                    <Separator Margin="0,14" Background="#2B3444"/>
                    <TextBlock Text="Selected block" Foreground="#F3F7FF" FontWeight="SemiBold"/>
                    <TextBlock x:Name="SelectionText" Text="None" Foreground="#AAB5C7" TextWrapping="Wrap" Margin="0,5,0,8"/>
                    <WrapPanel>
                        <Button Content="Paint" Click="PaintSelected_Click"/>
                        <Button Content="Rotate 90°" Click="RotateSelected_Click"/>
                        <Button Content="Flip H" Click="FlipHorizontalSelected_Click"/>
                        <Button Content="Flip V" Click="FlipVerticalSelected_Click"/>
                        <Button Content="Delete" Click="DeleteSelected_Click"/>
                    </WrapPanel>

                    <Separator Margin="0,14" Background="#2B3444"/>
                    <TextBlock Text="Controls" Foreground="#F3F7FF" FontWeight="SemiBold"/>
                    <TextBlock Foreground="#AAB5C7" TextWrapping="Wrap" Margin="0,4,0,0"
                               Text="Build mode: click the floor/side wire grid or a block face to place/attach. Select mode: click one block, Shift+click for multi-select. Right-click on a block opens actions. Ctrl+C/Ctrl+V copy/paste. Ctrl+Z/Ctrl+Y undo/redo add, delete, move and paint only. Right-drag rotates. Mouse wheel zooms. Arrow keys pan the whole scene. W/A/S/D/Q/E moves selected blocks."/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="1" Background="#0B0F15">
            <local:VoxelEditorControl x:Name="EditorViewport" Focusable="True" ClipToBounds="True" SnapsToDevicePixels="True" UseLayoutRounding="True"/>
            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Background="#AA121821" CornerRadius="10" Margin="16" Padding="12">
                <StackPanel>
                    <TextBlock Text="MonoGame 3D Editor" Foreground="#F3F7FF" FontWeight="Bold"/>
                    <TextBlock x:Name="StatsText" Text="0 blocks" Foreground="#C3CDDD"/>
                </StackPanel>
            </Border>
            <Border x:Name="ViewportInfoOverlay" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Background="#AA121821" CornerRadius="10" Margin="16" Padding="12" MinWidth="180">
                <StackPanel>
                    <TextBlock Text="Viewport info" Foreground="#F3F7FF" FontWeight="Bold"/>
                    <TextBlock x:Name="ViewportInfoText" Text="" Foreground="#C3CDDD" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Column="2" Background="#171D27" BorderBrush="#2B3444" BorderThickness="1,0,0,0" Padding="16">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Model" Foreground="#F3F7FF" FontSize="21" FontWeight="Bold"/>
                    <WrapPanel Margin="0,7,0,8">
                        <Button Content="New" Click="New_Click"/>
                        <Button Content="Save" Click="Save_Click"/>
                        <Button Content="Load" Click="Load_Click"/>
                    </WrapPanel>
                    <WrapPanel>
                        <Button Content="Sample Character" Click="Sample_Click"/>
                        <Button Content="Center Camera" Click="CenterCamera_Click"/>
                    </WrapPanel>
                    <Separator Margin="0,14" Background="#2B3444"/>
                    <TextBlock Text="Manual position" Foreground="#F3F7FF" FontWeight="SemiBold"/>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"><TextBlock Text="X" Foreground="#AAB5C7" HorizontalAlignment="Center"/><TextBox x:Name="XText" Text="0"/></StackPanel>
                        <StackPanel Grid.Column="1"><TextBlock Text="Y" Foreground="#AAB5C7" HorizontalAlignment="Center"/><TextBox x:Name="YText" Text="0"/></StackPanel>
                        <StackPanel Grid.Column="2"><TextBlock Text="Z" Foreground="#AAB5C7" HorizontalAlignment="Center"/><TextBox x:Name="ZText" Text="0"/></StackPanel>
                    </Grid>
                    <Button Content="Add block at X/Y/Z" Click="AddAtTextPosition_Click"/>
                    <Separator Margin="0,14" Background="#2B3444"/>
                    <TextBlock Text="Performance stress test" Foreground="#F3F7FF" FontWeight="SemiBold"/>
                    <WrapPanel Margin="0,4,0,0">
                        <Button Content="10k" Click="Generate10k_Click"/>
                        <Button Content="50k" Click="Generate50k_Click"/>
                        <Button Content="100k" Click="Generate100k_Click"/>
                        <Button Content="250k" Click="Generate250k_Click"/>
                        <Button Content="256³ Full" Click="Generate256Full_Click"/>
                    </WrapPanel>
                </StackPanel>
                <ListBox x:Name="PiecesList" Visibility="Collapsed" Height="0" SelectionMode="Extended" SelectionChanged="PiecesList_SelectionChanged"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
